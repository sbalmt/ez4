{
  "TestCdn": {
    "type": "@ez4/cdn",
    "name": "TestCdn",
    "file": "test/input/output-rewrite.ts",
    "context": {},
    "defaultOrigin": {
      "domain": "example.com",
      "type": "regular",
      "rewrite": [
        {
          "status": 301,
          "from": "/old/*",
          "to": "/new/*"
        },
        {
          "from": "/legacy/*",
          "to": "/internal/*"
        },
        {
          "from": "/exact",
          "to": "/exact-target"
        }
      ]
    },
    "origins": [
      {
        "domain": "mixed.com",
        "type": "regular",
        "path": "app/*",
        "rewrite": [
          {
            "status": 301,
            "from": "/app/old/*",
            "to": "/new/*"
          },
          {
            "from": "/app/internal/*",
            "to": "/modern/*"
          },
          {
            "from": "/app/redirect/*",
            "to": "https://docs.example.com/*",
            "status": 301
          },
          {
            "from": "/app/temporary/*",
            "to": "/temp/*",
            "status": 302
          }
        ]
      }
    ]
  }
}
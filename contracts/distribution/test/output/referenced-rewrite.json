{
  "ReferencedCdn": {
    "type": "@ez4/cdn",
    "name": "ReferencedCdn",
    "context": {},
    "defaultOrigin": {
      "domain": "example.com",
      "type": "regular",
      "rewrite": [
        {
          "from": "/old/*",
          "to": "/new/*",
          "status": 301
        },
        {
          "from": "/inline/*",
          "to": "/internal/*"
        }
      ]
    }
  }
}
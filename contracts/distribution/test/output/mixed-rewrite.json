{
  "MixedCdn": {
    "type": "@ez4/cdn",
    "name": "MixedCdn",
    "context": {},
    "defaultOrigin": {
      "domain": "example.com",
      "type": "regular",
      "rewrite": [
        {
          "from": "/legacy/*",
          "to": "/internal/*"
        },
        {
          "from": "/exact",
          "to": "/exact-target"
        }
      ]
    },
    "origins": [
      {
        "domain": "mixed.com",
        "type": "regular",
        "path": "app/*",
        "rewrite": [
          {
            "from": "/app/internal/*",
            "to": "/modern/*"
          },
          {
            "from": "/app/redirect/*",
            "to": "https://docs.example.com/*",
            "status": 301
          },
          {
            "from": "/app/temporary/*",
            "to": "/temp/*",
            "status": 302
          }
        ]
      }
    ]
  }
}
{
  "LegacyCdn": {
    "type": "@ez4/cdn",
    "name": "LegacyCdn",
    "file": "test/input/output-legacy-rewrite.ts",
    "context": {},
    "defaultOrigin": {
      "type": "regular",
      "domain": "example.com",
      "rewrite": [
        {
          "from": "/old/*",
          "to": "/new/*"
        },
        {
          "from": "/exact-path",
          "to": "/exact-target"
        }
      ]
    },
    "origins": [
      {
        "type": "regular",
        "domain": "legacy-class.com",
        "path": "api/*",
        "rewrite": [
          {
            "from": "/api/v1/*",
            "to": "/index.html"
          },
          {
            "from": "/api/v2/*",
            "to": "/app.html"
          }
        ]
      },
      {
        "type": "regular",
        "domain": "mixed.com",
        "path": "static/*",
        "rewrite": [
          {
            "from": "/static/images/*",
            "to": "/assets/img/*"
          },
          {
            "from": "/static/css/*",
            "to": "/assets/css/*"
          }
        ]
      }
    ]
  }
}
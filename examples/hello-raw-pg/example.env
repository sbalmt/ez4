# Connection string for the external Postgres (Supabase, Neon, RDS direct).
# Copy this file to `local.env` and fill in your own value. Never commit secrets.
#
# Var name format: EZ4_RAW_PG_<SERVICE_NAME>_URL (snake-uppercase).
# Service `Db` → `EZ4_RAW_PG_DB_URL`.
EZ4_RAW_PG_DB_URL=postgres://postgres:password@db.xyzcompany.supabase.co:5432/postgres?sslmode=require

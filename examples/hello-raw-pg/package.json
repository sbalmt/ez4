    "deploy": "tsc && ez4 deploy -e local.env",
    "destroy": "ez4 destroy -e local.env --force",
    "serve": "ez4 serve -e local.env"
  },
  "dependencies": {
    "@ez4/database": "^0.49.0",
    "@ez4/project": "^0.49.0",
    "@ez4/raw-pg": "^0.49.0"
  }
}
